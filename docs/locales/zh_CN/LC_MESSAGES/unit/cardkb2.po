#: 97d416bbdf544a0abe4a3d562d95df84 e79491e6762549fc8398c09e54ee162c of  
#: unit.cardkb.CardKBESPNOW.tick:1 unit.cardkb.CardKBUART.tick:1  
msgid "Poll the key buffer and trigger the callback if a key is available."  
msgstr "轮询按键缓冲区，并在有可用按键时触发回调函数。"  
  
#: 16f40235e2ec4e76885d033fb619cbad of unit.cardkb.CardKBUART.tick:3  
msgid ""  
"This method should be called periodically in the main loop to process key"  
" events received via UART."  
msgstr ""  
"此方法应在主循环中定期调用，以处理通过 UART 接收的按键事件。"  
  
#: 03c704895b924ed0a2258ba36d05c7d0 of unit.cardkb.CardKBESPNOW:1  
msgid "CardKB unit driver over ESP-NOW wireless communication."  
msgstr "基于 ESP-NOW 无线通信的 CardKB 单元驱动程序。"  
  
#: 09ed40b0093f44cfad8170bb69f9d6a4 of unit.cardkb.CardKBESPNOW:7  
msgid ""  
"Do not instantiate this class directly. Use :class:`CardKBUnit` with "  
"``mode=CardKBUnit.CardKB_ESP_NOW_MODE`` instead."  
msgstr ""  
"不要直接实例化此类。请改用 :class:`CardKBUnit` 并设置 ``mode=CardKBUnit.CardKB_ESP_NOW_MODE``。"  
  
#: 3c598c3188f94ba3ab3aa62a3e9ffb3c of unit.cardkb.CardKBESPNOW:12  
msgid ""  
"This class uses a broadcast MAC address (``ffffffffffff``) and fixes the "  
"Wi-Fi channel to 0. Key data is received asynchronously via IRQ callback."  
msgstr ""  
"此类使用广播 MAC 地址（``ffffffffffff``），并将 Wi-Fi 信道固定为 0。按键数据通过 IRQ 回调异步接收。"  
  
#: ea61ca47ef154a539b9ecc6afea32ddc of  
#: unit.cardkb.CardKBESPNOW.espnow_recv_callback:1  
msgid "Callback function invoked when an ESP-NOW packet is received."  
msgstr "在接收到 ESP-NOW 数据包时调用的回调函数。"  
  
#: 13ec09a1c5534768bb04c2c303d2ff7f of  
#: unit.cardkb.CardKBESPNOW.espnow_recv_callback:3  
msgid "The ESP-NOW object containing the received data."  
msgstr "包含接收数据的 ESP-NOW 对象。"  
  
#: 1ec32735d5134fd299dcb6c76bec011b of  
#: unit.cardkb.CardKBESPNOW.espnow_recv_callback:4  
msgid ""  
"``True`` if the frame is valid and a key was appended, ``False`` "  
"otherwise."  
msgstr ""  
"如果帧有效并且已追加按键数据，则为 ``True``，否则为 ``False``。"  
  
#: 6a48ba054c6f4f2889798da8ec4fc8b5 of unit.cardkb.CardKBESPNOW.get_key:1  
msgid "Get the next key from the buffer received via ESP-NOW."  
msgstr "从通过 ESP-NOW 接收的缓冲区中获取下一个按键。"  
  
#: 5527648c4367415bbbd60508a58325ca of unit.cardkb.CardKBESPNOW.get_key:3  
msgid "The key tuple ``(key_id, key_state)``, or ``None`` if the buffer is empty."  
msgstr "按键元组 ``(key_id, key_state)``，如果缓冲区为空则返回 ``None``。"  
  
#: 4962b205e5d24a49b3e08981ff2a5081 of unit.cardkb.CardKBESPNOW.is_pressed:1  
msgid "Check whether any key data is buffered from ESP-NOW."  
msgstr "检查是否存在来自 ESP-NOW 的按键数据缓冲。"  
  
#: c9313ac46dfd48909114b8263712be80 of unit.cardkb.CardKBESPNOW.is_pressed:3  
msgid "``True`` if there is buffered key data, ``False`` otherwise."  
msgstr "如果存在缓冲的按键数据则为 ``True``，否则为 ``False``。"  
  
#: f37ec8f6d4e0487db6c99ada6d30ddd2 of unit.cardkb.CardKBESPNOW.tick:3  
msgid ""  
"This method should be called periodically in the main loop to process key"  
" events received via ESP-NOW."  
msgstr ""  
"此方法应在主循环中定期调用，以处理通过 ESP-NOW 接收的按键事件。"