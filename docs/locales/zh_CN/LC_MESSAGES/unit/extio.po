#: ../../source/unit/extio.rst:117 6249d63e2f204677b07373c4d2ec594d
msgid ""
"A `Pin` object for further pin operations such as reading or writing "
"values."
msgstr "一个用于后续引脚操作（例如读取或写入值）的 `Pin` 对象。"

#: ../../source/unit/extio.rst:120 f0fe150fd1914ce89c7b50272151ad25
msgid "class Pin"
msgstr "class Pin"

#: ../../source/unit/extio.rst:128 6b71bf1c13ef406da491a69eb3d206b0
msgid "Initialize the Pin object with specified parameters."
msgstr "使用指定参数初始化 Pin 对象。"

#: ../../source/unit/extio.rst:130 74a2d89ab706454e84b5437e9fe952f9
msgid "The port object controlling the pin."
msgstr "控制该引脚的端口对象。"

