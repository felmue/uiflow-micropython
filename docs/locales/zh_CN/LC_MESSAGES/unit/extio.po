#: ../../source/unit/extio.rst:112 16e12664f1a34dcaa961b94f48012559
msgid "Provide a MicroPython-style interface for handling GPIO pins."
msgstr "提供一个 MicroPython 风格的接口，用于处理 GPIO 引脚。"

#: ../../source/unit/extio.rst:114 19834e037e32492e89ae78c5b77adbcb
msgid "The GPIO pin number to configure and control."
msgstr "要配置和控制的 GPIO 引脚编号。"

